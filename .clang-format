BasedOnStyle: LLVM

IndentWidth: 4
TabWidth: 4
UseTab: Never

BreakBeforeBraces: Allman
AccessModifierOffset: -4
AllowShortFunctionsOnASingleLine: Empty
AllowShortIfStatementsOnASingleLine: false

SpaceBeforeParens: ControlStatements
SpacesInParentheses: true

PointerAlignment: Left
DerivePointerAlignment: false

ColumnLimit: 0

# Unreal reflection macros
StatementMacros:
  - UCLASS
  - USTRUCT
  - UENUM
  - UINTERFACE

SortIncludes: CaseSensitive
IncludeBlocks: Regroup

IncludeCategories:
  # Generated header always last
  - Regex: '.*\.generated\.h"'
    Priority: 999

  # Engine / UE includes
  - Regex: '^"(Engine|Core|CoreMinimal|UObject|Components|GameFramework|Input|Net|Slate|Editor|Animation|Physics|AI|Niagara|Gameplay).*"'
    Priority: 1

  # Project includes
  - Regex: '^".*"'
    Priority: 2